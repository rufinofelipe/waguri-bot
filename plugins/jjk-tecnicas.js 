const handler = async (m, { conn }) => {
  try {
    // Obtener target вҖ” mencionado o el mismo usuario
    const mentioned = m.mentionedJid && m.mentionedJid[0]
    const target = mentioned || m.sender
    const user = global.db.data.users[target]
    const esPropio = target === m.sender

    if (!user || !user.jjk) {
      return conn.reply(
        m.chat,
        `в•ӯв”ҖгҖҢ вҡЎ *JUJUTSU KAISEN* гҖҚ\n` +
        `в”Ӯ\n` +
        `в”Ӯ вқҢ ${esPropio ? "AГәn no tienes personaje~" : "Ese hechicero no existe~"}\n` +
        `в”Ӯ рҹ’¬ Usa *.crear* para comenzar\n` +
        `в”Ӯ\n` +
        `в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ`,
        m
      )
    }

    const jjk = user.jjk
    const nombre = esPropio ? "Tus tГ©cnicas" : `TГ©cnicas de @${target.split("@")[0]}`

    const tecnicasTexto = jjk.tecnicas.map(t => {
      const info = TODAS_TECNICAS[t]
      if (!info) return `в”Ӯ\nв”Ӯ вңҰ *${t}*\nв”Ӯ   в”— Sin descripciГіn`
      return `в”Ӯ\nв”Ӯ ${info.emoji} *${t}*\nв”Ӯ   в”— ${info.descripcion}`
    }).join("\n")

    const bloqueadas = Object.entries(TODAS_TECNICAS).filter(([nombre, info]) => {
      return info.clan === jjk.clan && !jjk.tecnicas.includes(nombre)
    })

    const proximaTexto = bloqueadas.length > 0
      ? `в”Ӯ\nв”Ӯ рҹ”’ *PrГіxima:* ${bloqueadas[0][1].emoji} ${bloqueadas[0][0]}\nв”Ӯ    Nivel requerido: *${bloqueadas[0][1].nivel}*`
      : `в”Ӯ\nв”Ӯ вң… *ВЎTienes todas las tГ©cnicas!*`

    return conn.reply(
      m.chat,
      `в•ӯв”ҖгҖҢ вҡЎ *JUJUTSU KAISEN* гҖҚ\n` +
      `в”Ӯ\n` +
      `в”Ӯ вҡ”пёҸ *${nombre}*\n` +
      `в”Ӯ рҹ“Ҡ Nivel actual: *${jjk.nivel}*\n` +
      `в”Ӯ рҹ’ң Poder Maldito: *${jjk.poderMaldito}*\n` +
      `${tecnicasTexto}\n` +
      `в”Ӯ\n` +
      `в”Ӯ в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\n` +
      `${proximaTexto}\n` +
      `в”Ӯ\n` +
      `в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ`,
      m
    )

  } catch (e) {
    conn.reply(
      m.chat,
      `в•ӯв”ҖгҖҢ рҹҢё *WAGURI BOT* рҹҢё гҖҚ\nв”Ӯ\nв”Ӯ вқҢ OcurriГі un error~\nв”Ӯ вҡ пёҸ *${e.message}*\nв”Ӯ\nв•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ`,
      m
    )
