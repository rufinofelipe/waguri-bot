const handler = async (m, { conn, mentionedJid }) => {
  try {
    const target = mentionedJid && mentionedJid[0] ? mentionedJid[0] : m.sender
    const user = global.db.data.users[target]
    const esPropio = target === m.sender

    if (!user || !user.jjk) {
      return conn.reply(
        m.chat,
        `╭─「 ⚡ *JUJUTSU KAISEN* 」\n` +
        `│\n` +
        `│ ❌ ${esPropio ? "Aún no tienes personaje~" : "Ese hechicero no existe~"}\n` +
        `│ 💬 Usa *.crear* para comenzar\n` +
        `│\n` +
        `╰────────────────────`,
        m
      )
    }

    const jjk = user.jjk
    const nombre = esPropio ? "Tus técnicas" : `Técnicas de @${target.split("@")[0]}`

    // Construir lista de técnicas con info
    const tecnicasTexto = jjk.tecnicas.map(t => {
      const info = TODAS_TECNICAS[t]
      if (!info) return `│\n│ ${t}\n│ ┗ Sin descripción`
      return `│\n│ ${info.emoji} *${t}*\n│ ┗ ${info.descripcion}`
    }).join("\n")

    // Técnicas bloqueadas (las que no tiene aún)
    const bloqueadas = Object.entries(TODAS_TECNICAS).filter(([nombre, info]) => {
      return info.clan === jjk.clan || info.clan === "independiente" && jjk.clan === "independiente"
    }).filter(([nombre]) => !jjk.tecnicas.includes(nombre))

    const proximaTexto = bloqueadas.length > 0
      ? `│\n│ 🔒 *Próxima técnica:*\n│    ${bloqueadas[0][1].emoji} ${bloqueadas[0][0]} (Nivel ${bloqueadas[0][1].nivel})`
      : `│\n│ ✅ *¡Tienes todas las técnicas!*`

    return conn.reply(
      m.chat,
      `╭─「 ⚡ *JUJUTSU KAISEN* 」\n` +
      `│\n` +
      `│ ⚔️ *${nombre}*\n` +
      `│ 📊 Nivel actual: ${jjk.nivel}\n` +
      `${tecnicasTexto}\n` +
      `│\n` +
      `│ ══════════════════\n` +
      `${proximaTexto}\n` +
      `│\n` +
      `╰────────────────────`,
      m
    )

  } catch (e) {
    conn.reply(
      m.chat,
      `╭─「 🌸 *WAGURI BOT* 🌸 」\n│\n│ ❌ Ocurrió un error~\n│ ⚠️ *${e.message}*\n│\n╰────────────────────`,
      m
    )
  }
}

handler.command = handler.help = ["jjktecnicas", "tecnicas", "jjkt"]
handler.tags = ["jjk"]
handler.group = true
handler.register = true

export default handler
